{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "api/**"]
    },
    "backend#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "api/**"],
      "env": ["MONGO_URI", "PORT", "JWT_SECRET", "NODE_ENV", "CLIENT_URL"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
